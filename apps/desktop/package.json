{
  "name": "magnasoft-pos",
  "private": true,
  "version": "1.0.10",
  "description": "Serviteca POS - Sistema de punto de venta",
  "author": "JoelNaranjo20",
  "repository": {
    "type": "git",
    "url": "https://github.com/JoelNaranjo20/magnasoft-pos"
  },
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:compile": "tsc -p tsconfig.electron.json",
    "electron:dev": "concurrently \"pnpm dev\" \"wait-on tcp:5180 && pnpm electron:compile && pnpm cross-env NODE_ENV=development electron .\"",
    "electron:build": "pnpm build && pnpm electron:compile && electron-builder",
    "electron:publish": "vite build && pnpm electron:compile && dotenv -e .env.local -- electron-builder --publish always"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.10",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.469.0",
    "node-machine-id": "^1.1.12",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.11.0",
    "recharts": "^3.6.0",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@rollup/rollup-win32-x64-msvc": "4.24.4",
    "@types/node": "^20.19.27",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "dotenv-cli": "^11.0.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "postcss": "^8.4.49",
    "supabase": "^2.75.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4",
    "wait-on": "^8.0.1"
  }
}